{
    "redirects": [
        {
            "source": "/",
            "has": [{ "type": "host", "value": "www.knirkendegulve.dk" }],
            "destination": "https://knirkendegulve.dk/",
            "permanent": true
        },
        {
            "source": "/:path*",
            "has": [{ "type": "host", "value": "www.knirkendegulve.dk" }],
            "destination": "https://knirkendegulve.dk/:path*",
            "permanent": true
        },
        {
            "source": "/pages/arbejdsmetode.php",
            "destination": "/#processen",
            "permanent": true
        },
        {
            "source": "/pages/kontakt.php",
            "destination": "/#kontakt",
            "permanent": true
        },
        {
            "source": "/pages/",
            "destination": "/",
            "permanent": true
        },
        {
            "source": "/pages/:path*",
            "destination": "/",
            "permanent": true
        },
        {
            "source": "/mobil/",
            "destination": "/",
            "permanent": true
        },
        {
            "source": "/mobil/:path*",
            "destination": "/",
            "permanent": true
        }
    ]
}
